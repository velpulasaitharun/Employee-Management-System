@model IEnumerable<HRMS.Models.Attendance>

@{
    var employeeId = Context.Session.GetInt32("EmployeeId");
}

<h2>Attendance List</h2>

@* @if (User.IsInRole("Admin") || User.IsInRole("HR"))
{
    <div class="alert alert-info">
        Viewing Attendance Records
    </div>
}*@

@* @if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
} *@

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
} 

@if (ViewBag.IsMyAttendance == true)
{
    <p>
        <a asp-action="PunchIn"
           class="btn btn-success">
            Punch In
        </a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Employee Code</th>
            <th>Employee Name</th>
            <th>Date</th>
            <th>Punch In</th>
            <th>Punch Out</th>
            <th>Total Hours</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Employee?.EmployeeCode</td>

                <td>@item.Employee?.FullName</td>

                <td>
                    @item.AttendanceDate.ToString("dd-MMM-yyyy")
                </td>

                <td>
                    @(item.PunchIn == DateTime.MinValue
                                    ? "--"
                                    : item.PunchIn.ToString("dd-MMM-yyyy hh:mm tt"))
                                                                                </td>

                <td>
                    @(item.PunchOut.HasValue
                                    ? item.PunchOut.Value.ToString("dd-MMM-yyyy hh:mm tt")
                                    : "--")
                                       </td>

                <td>
                    @(item.TotalHours > 0
                                    ? item.TotalHours.ToString("0.00")
                                    : "--")
            </td>

                <td>@item.Status</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.AttendanceId"
                       class="btn btn-info btn-sm">
                        Details
                    </a>

                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <a asp-action="Edit"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                    }

                    @if (ViewBag.IsMyAttendance == true
                                    && item.PunchOut == null
                                    && item.AttendanceDate.Date == DateTime.Today
                                    && item.PunchIn != DateTime.MinValue)
                    {
                        <a asp-action="PunchOut"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-success btn-sm">
                            Punch Out
                        </a>
                    }

                   @*  @if (ViewBag.IsMyAttendance == true
                                    && item.PunchOut == null
                                    && item.AttendanceDate.Date == DateTime.Today
                                    && item.PunchIn != DateTime.MinValue)
                    {
                        <a asp-action="PunchOut"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-success btn-sm">
                            Punch Out
                        </a>
                    } *@


                  @*   @if (item.PunchOut == null
                                    && item.AttendanceDate.Date == DateTime.Today
                                    && item.PunchIn != DateTime.MinValue)
                    {
                        <a asp-action="PunchOut"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-success btn-sm">
                            Punch Out
                        </a>
                    } *@

                  @*   @if (item.EmployeeId == employeeId
                                    && item.PunchOut == null
                                    && item.PunchIn != DateTime.MinValue
                                    && item.AttendanceDate.Date == DateTime.Today)
                    {
                        <a asp-action="PunchOut"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-success btn-sm">
                            Punch Out
                        </a>
                    } *@

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete"
                           asp-route-id="@item.AttendanceId"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>


