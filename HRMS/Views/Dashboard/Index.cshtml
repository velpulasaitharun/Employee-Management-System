@*{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .dashboard-header h2 {
        margin: 0;
        font-weight: 700;
        letter-spacing: 0.25px;
    }

    .dashboard-subtitle {
        color: #6b7280;
        margin: 0;
    }

    .kpi-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: linear-gradient(160deg, #ffffff, #f8fafc);
        box-shadow: 0 12px 25px rgba(15, 23, 42, 0.06);
        height: 100%;
    }

    .kpi-card .card-body {
        padding: 1rem;
    }

    .kpi-label {
        margin: 0;
        color: #64748b;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .kpi-value {
        margin: 0.35rem 0 0;
        font-size: 1.9rem;
        font-weight: 700;
        color: #0f172a;
    }

    .kpi-accent {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: #fff;
    }

    .accent-employees { background: #1d4ed8; }
    .accent-departments { background: #0f766e; }
    .accent-designations { background: #7c3aed; }
    .accent-leaves { background: #d97706; }
    .accent-payroll { background: #be123c; }
</style>

<div class="container-fluid px-0">

    <div class="dashboard-header">
        <div>
            <h2>HRMS Dashboard</h2>
            <p class="dashboard-subtitle">Live overview of core workforce operations.</p>
        </div>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <div class="row">

            <div class="col-md-4 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Total Employees</p>
                        <h3 class="kpi-value">@ViewBag.TotalEmployees</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Total Departments</p>
                        <h3 class="kpi-value">@ViewBag.TotalDepartments</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Total Designations</p>
                        <h3 class="kpi-value">@ViewBag.TotalDesignations</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Total Leave Requests</p>
                        <h3 class="kpi-value">@ViewBag.TotalLeaves</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Total Payroll Records</p>
                        <h3 class="kpi-value">@ViewBag.TotalPayrolls</h3>
                    </div>
                </div>
            </div>

        </div>
    }
    else
    {
        <div class="row">

            <div class="col-md-3 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">My Attendance</p>
                        <h3 class="kpi-value">@ViewBag.MyAttendance</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">My Leaves</p>
                        <h3 class="kpi-value">@ViewBag.MyLeaves</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">Pending Leaves</p>
                        <h3 class="kpi-value">@ViewBag.PendingLeaves</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card kpi-card">
                    <div class="card-body">
                        <p class="kpi-label">My Payrolls</p>
                        <h3 class="kpi-value">@ViewBag.MyPayrolls</h3>
                    </div>
                </div>
            </div>

        </div>
    }

</div>

