@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <div class="dashboard-header">
        <h2>HRMS Dashboard</h2>
        <p>Workforce Analytics & Employee Management System</p>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <!-- KPI CARDS -->
        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="card kpi-card bg-blue">
                    <div class="card-body">
                        <div class="kpi-title">Total Employees</div>
                        <div class="kpi-value">@ViewBag.TotalEmployees</div>
                        <div class="kpi-icon">👨‍💼</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card kpi-card bg-green">
                    <div class="card-body">
                        <div class="kpi-title">Departments</div>
                        <div class="kpi-value">@ViewBag.TotalDepartments</div>
                        <div class="kpi-icon">🏢</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card kpi-card bg-purple">
                    <div class="card-body">
                        <div class="kpi-title">Designations</div>
                        <div class="kpi-value">@ViewBag.TotalDesignations</div>
                        <div class="kpi-icon">🎯</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card kpi-card bg-orange">
                    <div class="card-body">
                        <div class="kpi-title">Leave Requests</div>
                        <div class="kpi-value">@ViewBag.TotalLeaves</div>
                        <div class="kpi-icon">📅</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card kpi-card bg-red">
                    <div class="card-body">
                        <div class="kpi-title">Payroll Records</div>
                        <div class="kpi-value">@ViewBag.TotalPayrolls</div>
                        <div class="kpi-icon">💰</div>
                    </div>
                </div>
            </div>

        </div>

        <!-- OVERVIEW SECTION -->
        <div class="row">

            <div class="col-md-6 mb-4">
                <div class="quick-card">

                    @if (User.IsInRole("Admin"))
                    {
                        <h4>Administration Overview</h4>
                        <hr />
                        <p>✔ User & Role Management</p>
                        <p>✔ Employee Management</p>
                        <p>✔ Attendance Monitoring</p>
                        <p>✔ Leave Approvals</p>
                        <p>✔ Payroll Management</p>
                        <p>✔ Audit Tracking</p>
                    }
                    else if (User.IsInRole("HR"))
                    {
                        <h4>HR Operations Overview</h4>
                        <hr />
                        <p>✔ Employee Records</p>
                        <p>✔ Attendance Tracking</p>
                        <p>✔ Leave Management</p>
                        <p>✔ Payroll Processing</p>
                    }

                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="quick-card">
                    <h4>System Status</h4>
                    <hr />

                    <div class="row text-center">

                        <div class="col-4">
                            <h3>@ViewBag.TotalEmployees</h3>
                            <small>Employees</small>
                        </div>

                        <div class="col-4">
                            <h3>@ViewBag.TotalLeaves</h3>
                            <small>Leaves</small>
                        </div>

                        <div class="col-4">
                            <h3>@ViewBag.TotalPayrolls</h3>
                            <small>Payrolls</small>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    }
    else
    {
        <div class="row">

            <div class="col-md-3 mb-4">
                <div class="card kpi-card bg-blue">
                    <div class="card-body">
                        <div class="kpi-title">Attendance</div>
                        <div class="kpi-value">@ViewBag.MyAttendance</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card kpi-card bg-green">
                    <div class="card-body">
                        <div class="kpi-title">My Leaves</div>
                        <div class="kpi-value">@ViewBag.MyLeaves</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card kpi-card bg-orange">
                    <div class="card-body">
                        <div class="kpi-title">Pending Leaves</div>
                        <div class="kpi-value">@ViewBag.PendingLeaves</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card kpi-card bg-red">
                    <div class="card-body">
                        <div class="kpi-title">My Payrolls</div>
                        <div class="kpi-value">@ViewBag.MyPayrolls</div>
                    </div>
                </div>
            </div>

        </div>
    }

</div>





