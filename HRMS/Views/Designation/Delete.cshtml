@model HRMS.Models.Designation

<h2>Delete Designation</h2>

<h4>
    Are you sure you want to delete this designation?
</h4>

<div>
    <strong>
        @Model.DesignationName
    </strong>
</div>

<br />

<form asp-action="Delete">

    <input type="hidden"
           asp-for="DesignationId" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>