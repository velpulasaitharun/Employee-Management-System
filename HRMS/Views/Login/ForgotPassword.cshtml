@model HRMS.ViewModels.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<h1 class="auth-title">Forgot Password</h1>
<p class="auth-subtitle">Submit your username and contact HR/Admin for reset assistance.</p>

<form asp-action="ForgotPassword" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-auth text-white w-100">Submit Request</button>

    <div class="auth-links">
        <a asp-action="Login">Back to login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
