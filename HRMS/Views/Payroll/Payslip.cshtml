@model HRMS.Models.Payroll

<h2>Employee Payslip</h2>

<table class="table table-bordered">

    <tr>
        <th>Employee</th>
        <td>@Model.Employee?.FirstName @Model.Employee?.LastName</td>
    </tr>
    <tr>
        <th>Month</th>
        <td>@Model.PayMonth.ToString("MMMM yyyy")</td>
    </tr>
    <tr>
        <th>Basic Salary</th>
        <td>@Model.BasicSalary</td>
    </tr>

    <tr>
        <th>HRA</th>
        <td>@Model.HRA</td>
    </tr>

    <tr>
        <th>DA</th>
        <td>@Model.DA</td>
    </tr>

    <tr>
        <th>PF</th>
        <td>@Model.PF</td>
    </tr>

    <tr>
        <th>Tax</th>
        <td>@Model.ProfessionalTax</td>
    </tr>
    <tr>
        <th><b>Gross Salary</b></th>
        <td><b>@Model.GrossSalary</b></td>
    </tr>

    <tr>
        <th><b>Net Salary</b></th>
        <td><b>@Model.NetSalary</b></td>
    </tr>

</table>

<button onclick="window.print()"
        class="btn btn-success">
    Print Payslip
</button>